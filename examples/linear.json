{
  "name": "linear",
  "inputs": [
    {"name": "x", "shape": [2, 3], "dtype": "float32"}
  ],
  "constants": [
    {"name": "w", "dtype": "float32", "value": [[0.2, -0.4], [0.5, 0.1], [-0.3, 0.8]]},
    {"name": "b", "dtype": "float32", "value": [[0.1, -0.2]]}
  ],
  "nodes": [
    {"op": "matmul", "inputs": ["x", "w"], "outputs": ["xw"]},
    {"op": "add", "inputs": ["xw", "b"], "outputs": ["y"]}
  ],
  "outputs": ["y"]
}
